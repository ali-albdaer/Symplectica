{
    "name": "space-simulator",
    "private": true,
    "workspaces": [
        "src/client",
        "src/server"
    ],
    "scripts": {
        "wasm:build": "cd src/physics-core && wasm-pack build --release --target web",
        "postinstall": "npm run wasm:build",
        "client:dev": "npm run -w @nbody/client dev",
        "server:dev": "npm run -w @nbody/server dev",
        "client:build": "npm run -w @nbody/client build",
        "server:build": "npm run -w @nbody/server build",
        "build": "npm run wasm:build && npm run client:build && npm run server:build",
        "start": "npm run -w @nbody/server start",
        "dev": "concurrently -k \"npm:server:dev\" \"npm:client:dev\"",
        "bench": "node scripts/bench.js",
        "bench:quick": "node scripts/bench.js scripts/bench-path-quick.json"
    },
    "devDependencies": {
        "concurrently": "^9.1.0",
        "playwright": "^1.61.1",
        "wasm-pack": "^0.14.0"
    }
}
